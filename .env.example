# ═══════════════════════════════════════════════════════════════════
#  OSINT-D2 — Environment Configuration
# ═══════════════════════════════════════════════════════════════════
#
#  Copy this file to `.env` and fill in your secrets.
#  NEVER commit `.env` to version control.
#
#  Alternatively, run: osint-d2 doctor setup-ai
#  for interactive configuration (no manual editing needed).
# ═══════════════════════════════════════════════════════════════════

# ── AI Provider (DeepSeek / OpenAI-compatible) ──────────────────
# Required for AI analysis and agent mode.
# Supports: DeepSeek, Groq, OpenRouter, HuggingFace, or any OpenAI-compatible API.
# If not set, OSINT-D2 falls back to a local heuristic summary (no network calls).
OSINT_D2_AI_API_KEY=
OSINT_D2_AI_BASE_URL=https://api.deepseek.com
OSINT_D2_AI_MODEL=deepseek-chat
OSINT_D2_AI_TIMEOUT_SECONDS=45
OSINT_D2_AI_MAX_RETRIES=3

# ── ScrapingAnt Proxy ───────────────────────────────────────────
# Enterprise-grade proxy infrastructure for bypassing rate limits
# and anti-bot blocks on social platforms.
# Get your key at: https://scrapingant.com/?ref=osint-d2
OSINT_D2_PROXY_API_KEY=
OSINT_D2_PROXY_USERNAME=
OSINT_D2_PROXY_MODE=residential
# Options: 'residential' (recommended) or 'datacenter'
OSINT_D2_PROXY_COUNTRY=
# 2-letter country code (e.g. 'us', 'de', 'br'). Empty = auto.

# ── HTTP Defaults ───────────────────────────────────────────────
OSINT_D2_HTTP_TIMEOUT_SECONDS=20
OSINT_D2_USER_AGENT=osint-d2/0.1 (+https://local)

# ── Language ────────────────────────────────────────────────────
# Default language for CLI prompts, AI analysis, and PDF reports.
# Options: en, es, pt, ar, ru
OSINT_D2_DEFAULT_LANGUAGE=en

# ── Site-lists (data-driven, WhatsMyName-style) ─────────────────
# Local paths to JSON datasets for extended scanning.
# Leave empty to use built-in sources only.
OSINT_D2_USERNAME_SITES_PATH=
OSINT_D2_EMAIL_SITES_PATH=

# ── Concurrency & Filters ──────────────────────────────────────
# ⚠️  High concurrency without rate limiting constitutes DoS-adjacent
#     behaviour against scanned platforms. Keep these at responsible values.
OSINT_D2_SITES_MAX_CONCURRENCY=30
OSINT_D2_SITES_NO_NSFW=true

# ── Rate Limiting (responsible scanning) ────────────────────────
# Per-domain throttling to prevent IP bans and false negatives.
# These defaults are tuned for accuracy without being hostile.
OSINT_D2_REQUEST_DELAY_MS=200
# Minimum delay (ms) between requests to the same domain.
OSINT_D2_REQUEST_JITTER_MS=100
# Random jitter ± (ms) added to the delay for naturalness.
OSINT_D2_PER_DOMAIN_CONCURRENCY=3
# Max simultaneous requests to the same domain (CDN/origin).
OSINT_D2_RETRY_MAX_ATTEMPTS=3
# Retries on 429/503 responses with exponential backoff.

# ── Agent Mode ──────────────────────────────────────────────────
# Default max reasoning steps for autonomous agent investigations.
OSINT_D2_AGENT_MAX_STEPS=10

